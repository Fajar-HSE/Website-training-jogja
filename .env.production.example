# Environment Variables untuk Production (Vercel)
# Salin key ini ke Vercel Dashboard → Settings → Environment Variables
# JANGAN isi nilai asli di sini — file ini boleh masuk repo

# Base URL WordPress REST API (WAJIB)
NEXT_PUBLIC_WP_API_URL=https://training-jogja.com/wp-json/wp/v2

# Secret untuk on-demand revalidation webhook dari WordPress
REVALIDATE_SECRET=isi-dengan-token-rahasia-yang-panjang
